{
  "manifest_version": 3,
  "name": "A11YO — Accessibility Checker",
  "version": "1.0.0",
  "description": "Plain English accessibility report for any website. Find WCAG issues explained for real people.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://a11yo.io/*",
    "https://*.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "A11YO Accessibility Checker",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Anthropic Claude — https://console.anthropic.com/settings/keys
# Required for: /tools/alt-text (AI alt text generation)
ANTHROPIC_API_KEY=sk-ant-...

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs — https://dashboard.stripe.com/products
# Create two products (Pro €29/mo, Agency €79/mo) and paste the price IDs here
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# Base URL used in shareable report links and Stripe redirect URLs
NEXT_PUBLIC_BASE_URL=https://a11yo.io

# Optional: path to local Chrome for dev (skipped on Vercel)
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# ── Supabase migrations to run (in order) ──────────────────────────
# 1. supabase/schema.sql      — scans table
# 2. supabase/waitlist.sql    — waitlist table
# 3. supabase/profiles.sql    — profiles table + auto-create trigger
# 4. supabase/rate-limits.sql — rate_limits table + check_and_increment_rate_limit fn
